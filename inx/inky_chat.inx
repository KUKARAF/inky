<?xml version="1.0" encoding="UTF-8"?>
<inkscape-extension xmlns="http://www.inkscape.org/namespace/inkscape/extension">
    <name>Chat Assistant...</name>
    <id>com.inky.chat</id>
    <effect>
        <object-type>all</object-type>
        <effects-menu>
            <submenu name="Claude AI"/>
        </effects-menu>
    </effect>
    <script>
        <command location="inx" interpreter="python">inky/extensions/chat.py</command>
    </script>
</inkscape-extension>
